; Database Configuration (MySQL/XAMPP)
DB_HOST=127.0.0.1
DB_NAME=pcu_rfid2
DB_USER=root
DB_PASS=

; Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/pcuRFID2/google_callback.php
GOOGLE_APP_NAME=GateWatchProject

; Email Configuration - Gmail SMTP (requires App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=GateWatchProject

; Security - JWT Secret for Digital ID
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

; Admin Account Configuration (Auto-created on first database connection)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

; Security Gate Monitor Credentials
SECURITY_USERNAME=security@example.com
SECURITY_PASSWORD=change-this-password
ADMIN_NAME=System Administrator

; Super Admin Configuration (Auto-created on first login page access)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=change-this-password
SUPERADMIN_NAME=Super Admin

; Face Recognition Configuration
FACE_RECOGNITION_ENABLED=true
FACE_MATCH_THRESHOLD=0.6
FACE_ENCRYPTION_KEY=change-this-to-a-64-char-hex-key
FACE_MAX_DESCRIPTORS_PER_STUDENT=5
FACE_MIN_CONFIDENCE=0.5
