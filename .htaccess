# Deny access to environment configuration file
<Files "env">
    Require all denied
</Files>

# Deny access to composer files (recommended security practice)
<FilesMatch "^composer\.(json|lock)$">
    Require all denied
</FilesMatch>

# Deny access to vendor directory via web (optional but recommended)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^vendor/.*$ - [F,L]
</IfModule>
